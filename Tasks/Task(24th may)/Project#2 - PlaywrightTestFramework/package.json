  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "playwright": "^1.40.0",
    "winston": "^3.11.0"
  }
}
