{
  "name": "playwright-salesforce-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright automation framework for Salesforce",
  "main": "dist/index.js",
  "scripts": {
    "test": "playwright test",
    "test:valid": "npx ts-node src/tests/ValidLoginTest.ts",
